# ═══════════════════════════════════════════════════════════════
# CalmTree Discover — Environment Variables
# Copy this to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
# Public keys (safe for client-side — RLS handles authorization)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Site ──────────────────────────────────────────────────────
VITE_SITE_URL=https://calmtree.com

# ── Payment Gateway (Razorpay) ────────────────────────────────
# Server-only — never prefixed with VITE_
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── YouTube Data API (optional — for auto-fetching videos) ────
VITE_YOUTUBE_API_KEY=
VITE_YOUTUBE_CHANNEL_ID=

# ── Server-only ───────────────────────────────────────────────
NODE_ENV=development
