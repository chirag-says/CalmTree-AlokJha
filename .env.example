# ═══════════════════════════════════════════════════════════════
# CalmTree Discover — Environment Variables
# Copy this to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Supabase (required) ───────────────────────────────────────
# Public keys (safe for client-side — RLS handles authorization)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=

# Server-only — used by server functions (getAdminClient). NEVER expose to browser.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────
VITE_SITE_URL=https://calmtree.in
# The separate admin app's URL — used by the "Admin" link shown to admins.
VITE_ADMIN_URL=https://admin.calmtree.in
# Do NOT set NODE_ENV here or on Vercel — it forces a development build of
# React and crashes SSR in production ("jsxDEV is not a function").

# ── Payment Gateway (Razorpay) ────────────────────────────────
# Server-only — never prefixed with VITE_
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Set this separately in Razorpay dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=

# ── Cloudinary (required for ebook PDF delivery) ──────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── PostHog analytics (optional — app works fine without it) ──
# Get these from: https://us.posthog.com/settings/project
VITE_POSTHOG_KEY=
# Default: https://app.posthog.com  |  US cloud: https://us.i.posthog.com
VITE_POSTHOG_HOST=https://us.i.posthog.com
