# ═══════════════════════════════════════════════════════════════
# CalmTree ADMIN — Environment Variables
# Copy this to admin/.env and fill in your values.
# Uses the SAME Supabase project as the client site.
# ═══════════════════════════════════════════════════════════════

# ── Supabase (required) ───────────────────────────────────────
# Public keys (safe for browser — RLS + is_admin gate access)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=

# Server-only — the admin server functions use the service role. NEVER expose to browser.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudinary (required — ebook PDF/cover uploads + signed delivery) ─
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── PostHog analytics (optional — powers the /admin/analytics page + per-user
#    activity timelines). Server-only: the Personal API Key is a SECRET and is
#    never sent to the browser. Without these, analytics degrades to a setup
#    notice and the rest of the admin works normally.
#    Create the key at: PostHog → Settings → Personal API Keys → scope "Query Read".
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_API_HOST=
