# ═══════════════════════════════════════════════════════════════
# CalmTree ADMIN — Environment Variables
# Copy this to admin/.env and fill in your values.
# Uses the SAME Supabase project as the client site.
# ═══════════════════════════════════════════════════════════════

# ── Supabase (required) ───────────────────────────────────────
# Public keys (safe for browser — RLS + is_admin gate access)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=

# Server-only — the admin server functions use the service role. NEVER expose to browser.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudinary (only needed once admin ebook uploads are wired) ─
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
